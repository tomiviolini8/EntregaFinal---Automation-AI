      "parameters": {
        "jsCode": "// Terminos de busqueda generados dinamicamente (no hardcodeados en el HTTP).\n// Si el Perfil trae Keywords, se usan; si no, fallback a terminos por defecto.\nconst kw = ($('Set - Guardar contexto CV').first().json.keywords || '').trim();\n\nlet terminos;\nif (kw) {\n  terminos = kw.split(',').map(t => t.trim()).filter(Boolean);\n} else {\n  terminos = [\n    'process analyst',\n    'business analyst',\n    'continuous improvement',\n    'operations analyst',\n    'data analyst'\n  ];\n}\n\nreturn terminos.map(t => ({ json: { termino: t } }));"
      },
