    {
      "parameters": {
        "jsCode": "// Ordena por score desc, toma top 10, arma HTML del email de aprobacion.\n// El link de aprobacion usa la resumeUrl REAL del nodo Wait (HITL correcto).\nconst raw = $input.first().json.data || [];\n// Airtable devuelve los campos dentro de \"fields\" con mayuscula. Los normalizamos.\nconst items = raw.map(r => ({\n  titulo: r.fields?.Titulo || r.titulo,\n  empresa: r.fields?.Empresa || r.empresa,\n  ubicacion: r.fields?.Ubicacion || r.ubicacion,\n  url: r.fields?.URL || r.url,\n  score: r.fields?.Score ?? r.score,\n  justificacion: r.fields?.Justificacion || r.justificacion\n}));\nconst top10 = items\n  .filter(v => v.score != null)\n  .sort((a, b) => b.score - a.score)\n  .slice(0, 10);\n\nif (top10.length === 0) {\n  return [{ json: { vacio: true, total: 0, top10: [], html: '<p>No se encontraron vacantes en este ciclo.</p>' } }];\n}\n\n// resumeUrl unica de esta ejecucion (la genera el nodo Wait).\nconst resumeUrl = $execution.resumeUrl;\nconst urlAprobar = `${resumeUrl}&decision=aprobar`;\nconst urlRechazar = `${resumeUrl}&decision=rechazar`;\n\nconst filas = top10.map((v) => `\n    <tr style=\"border-bottom:1px solid #eee\">\n      <td style=\"padding:10px;font-weight:bold;font-size:18px;color:#2c3e50\">${v.score}</td>\n      <td style=\"padding:10px\">\n        <a href=\"${v.url}\" style=\"color:#2980b9;font-weight:bold;text-decoration:none\">${v.titulo}</a><br>\n        <span style=\"color:#888;font-size:13px\">${v.empresa} &middot; ${v.ubicacion}</span><br>\n        <span style=\"color:#555;font-style:italic;font-size:13px\">${v.justificacion}</span>\n      </td>\n    </tr>`).join('');\n\nconst html = `\n  <div style=\"font-family:Arial,sans-serif;max-width:640px;margin:auto\">\n    <h2 style=\"color:#2c3e50\">Top ${top10.length} vacantes para vos</h2>\n    <p style=\"color:#555\">El sistema analizo y puntuo estas vacantes contra tu CV. Revisalas y decidi:</p>\n    <table style=\"width:100%;border-collapse:collapse\">\n      <tr style=\"background:#f4f6f7\">\n        <th style=\"padding:10px;text-align:left;color:#2c3e50\">Score</th>\n        <th style=\"padding:10px;text-align:left;color:#2c3e50\">Vacante</th>\n      </tr>\n      ${filas}\n    </table>\n    <div style=\"margin-top:24px;text-align:center\">\n      <a href=\"${urlAprobar}\" style=\"background:#27ae60;color:#fff;padding:14px 28px;text-decoration:none;border-radius:6px;margin-right:12px;font-weight:bold\">APROBAR Y ENVIAR DIGEST</a>\n      <a href=\"${urlRechazar}\" style=\"background:#e74c3c;color:#fff;padding:14px 28px;text-decoration:none;border-radius:6px;font-weight:bold\">RECHAZAR LOTE</a>\n    </div>\n    <p style=\"color:#aaa;font-size:11px;margin-top:20px\">Examen Final - Ecosistema de Automatizacion IA. Este correo espera tu aprobacion (HITL) antes de ejecutar la accion final.</p>\n  </div>`;\n\nreturn [{ json: { vacio: false, html, top10, total: top10.length } }];"
      },
