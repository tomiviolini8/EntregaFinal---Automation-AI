    {
      "parameters": {
        "jsCode": "// Recupera el top10 guardado antes del Wait y arma el digest final.\nconst top10 = $('Code - Top 10 + HTML aprobacion').first().json.top10 || [];\n\nconst tarjetas = top10.map(v => `\n  <div style=\"border:1px solid #e0e0e0;border-radius:8px;padding:16px;margin-bottom:14px;font-family:Arial,sans-serif\">\n    <h3 style=\"margin:0;color:#2c3e50\">${v.titulo} <span style=\"color:#27ae60\">(${v.score}/100)</span></h3>\n    <p style=\"margin:6px 0;color:#666\">${v.empresa} &middot; ${v.ubicacion}</p>\n    <p style=\"font-style:italic;color:#888;margin:6px 0\">${v.justificacion}</p>\n    <a href=\"${v.url}\" style=\"color:#2980b9;font-weight:bold\">Ver y postularme &rarr;</a>\n  </div>`).join('');\n\nconst html = `\n  <div style=\"max-width:640px;margin:auto;font-family:Arial,sans-serif\">\n    <h2 style=\"color:#2c3e50\">Tu digest de vacantes aprobadas</h2>\n    ${tarjetas}\n  </div>`;\nreturn [{ json: { html, total: top10.length } }];"
      },
